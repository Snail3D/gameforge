const WIDTH = 720;
const HEIGHT = 720;
const SIDE_LENGTH = 90;
const COLOR_DARK = "#795548";
const COLOR_LIGHT = "#F0D9B5";

// Game State Variables
let boardState = [];
let currentTurn = "White";
let gameStateStatus = "IN_PROGRESS";

// Input State Management
let playerInput = {
    selectedPiece: null,
    potentialMoves: []
};

// Game History/State Tracking Variables (Added for advanced moves)
let gameHistory = [];
let canCastle = {
    White: { kingside: true, queenside: true },
    Black: { kingside: true, queenside: true }
};

/**
 * Defines the structure for a Piece object.
 * @typedef {Object} Piece
 * @property {'P' | 'R' | 'N' | 'B' | 'Q' | 'K'} type - The type of piece ('P', 'R', 'N', 'B', 'Q', 'K').
 * @property {'White' | 'Black'} color - The color of the piece.
 */

/**
 * Defines the structure for coordinates.
 * @typedef {Object} Coords
 * @property {number} r - Row index (0-7).
 * @property {number} c - Column index (0-7).
 */

/**
 * Defines the structure for a Move Result.
 * @typedef {Object} MoveResult
 * @property {boolean} madeMove - True if the board state was modified.
 * @property {boolean} castlingUpdate - True if castling rights were used or updated.
 * @property {Object} castlingData - Updates to the canCastle structure.
 */


/**
 * Initializes the 8x8 board state array with null (representing empty squares).
 * @returns {Array<Array<null | Piece>>} The initialized board state.
 */
function initializeBoard() {
    let board = [];
    for (let i = 0; i < 8; i++) {
        board[i] = [];
        for (let j = 0; j < 8; j++) {
            board[i][j] = null;
        }
    }
    return board;
}

/**
 * Creates a standardized piece object.
 * @param {string} type - The piece type.
 * @param {'White' | 'Black'} color - The color.
 * @returns {Piece} A new piece object.
 */
function createPiece(type, color) {
    return { type: type, color: color };
}

/**
 * Creates a piece object and sets it directly onto the specified board location.
 * @param {string} type - The piece type.
 * @param {'White' | 'Black'} color - The color.
 * @param {number} r - The row index (0-7).
 * @param {number} c - The column index (0-7).
 * @returns {Piece} The created piece object.
 */
function createPieceAt(type, color, r, c) {
    const piece = createPiece(type, color);
    boardState[r][c] = piece;
    return piece;
}

/**
 * Initializes the 8x8 board state array and places all 32 starting pieces.
 * Populates the boardState array systematically for all 32 pieces.
 */
function setInitialPieces(board) {
    const ROOK = 'R';
    const KNIGHT = 'N';
    const BISHOP = 'B';
    const QUEEN = 'Q';
    const KING = 'K';
    const PAWN = 'P';

    // The piece arrangement for a rank of 8 pieces
    const pieceOrder = [ROOK, KNIGHT, BISHOP, QUEEN, KING, BISHOP, KNIGHT, ROOK];

    // White pieces setup: Ranks 1 (index 0) and 2 (index 1)
    // Rank 1 (Back Rank, r=0)
    for (let c = 0; c < 8; c++) {
        createPieceAt(pieceOrder[c], 'White', 0, c);
    }
    // Rank 2 (Pawns, r=1)
    for (let c = 0; c < 8; c++) {
        createPieceAt(PAWN, 'White', 1, c);
    }

    // Black pieces setup: Ranks 8 (index 7) and 7 (index 6)
    // Rank 8 (Back Rank, r=7)
    for (let c = 0; c < 8; c++) {
        createPieceAt(pieceOrder[c], 'Black', 7, c);
    }
    // Rank 7 (Pawns, r=6)
    for (let c = 0; c < 8; c++) {
        createPieceAt(PAWN, 'Black', 6, c);
    }
}

/**
 * Draws the chessboard grid and sets up the initial background.
 * @param {CanvasRenderingContext2D} ctx - The context to draw on.
 */
function drawBoardGrid(ctx) {
    for (let r = 0; r < 8; r++) {
        for (let c = 0; c < 8; c++) {
            // Standard chess coloring: (r+c)%2 = 0 is one color, 1 is the other.
            // Assuming the top-left (0,0) corresponds to a 'dark' square for this implementation.
            const finalColor = ((r + c) % 2 === 0) ? COLOR_DARK : COLOR_LIGHT;
            
            const x = c * SIDE_LENGTH;
            const y = r * SIDE_LENGTH;
            
            ctx.fillStyle = finalColor;
            ctx.fillRect(x, y, SIDE_LENGTH, SIDE_LENGTH);
        }
    }
}

/**
 * Maps piece types to Unicode symbols and determines display color.
 * @param {Piece | null} piece - The piece object or null.
 * @returns {{symbol: string, color: string}} The symbol and its display color.
 */
function getPieceDisplayInfo(piece) {
    if (!piece) return { symbol: '', color: 'transparent' };
    
    let symbol;
    let color;

    if (piece.color === 'White') {
        // White symbols (Uppercase Unicode)
        switch (piece.type) {
            case 'R': symbol = '♖'; break;
            case 'N': symbol = '♘'; break;
            case 'B': symbol = '♗'; break;
            case 'Q': symbol = '♕'; break;
            case 'K': symbol = '♔'; break;
            case 'P': symbol = '♙'; break;
            default: symbol = '?';
        }
        color = '#000'; // Black text color
    } else { // Black
        // Black symbols (Unicode usually renders darker/black)
        switch (piece.type) {
            case 'R': symbol = '♜'; break;
            case 'N': symbol = '♞'; break;
            case 'B': symbol = '♝'; break;
            case 'Q': symbol = '♛'; break;
            case 'K': symbol = '♚'; break;
            case 'P': symbol = '♟'; break;
            default: symbol = '?';
        }
        color = '#FFF'; // White text color (Allows the contrast of the unicode symbol)
    }
    return { symbol, color };
}

/**
 * Draws all pieces currently on the board state.
 * @param {CanvasRenderingContext2D} ctx - The context to draw on.
 */
function drawPieces(ctx) {
    for (let r = 0; r < 8; r++) {
        for (let c = 0; c < 8; c++) {
            const piece = boardState[r][c];
            if (piece) {
                const { symbol, color } = getPieceDisplayInfo(piece);
                
                const x = c * SIDE_LENGTH;
                const y = r * SIDE_LENGTH;
                
                // Use a font size that looks good across the square
                ctx.font = `${SIDE_LENGTH * 0.7}px Arial Unicode MS`; 
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                
                ctx.fillStyle = color;
                ctx.fillText(symbol, x + SIDE_LENGTH / 2, y + SIDE_LENGTH / 2);
            }
        }
    }
}

/**
 * Draws any visual feedback for selection or potential moves.
 * @param {CanvasRenderingContext2D} ctx - The context to draw on.
 */
function drawSelectionVisuals(ctx) {
    if (!playerInput.selectedPiece) return;

    const { r: startR, c: startC } = getCoordsFromPiece(playerInput.selectedPiece);
    
    // 1. Highlight the selected piece's square
    ctx.fillStyle = 'rgba(100, 100, 100, 0.3)'; // Dim grey overlay
    ctx.fillRect(startC * SIDE_LENGTH, startR * SIDE_LENGTH, SIDE_LENGTH, SIDE_LENGTH);

    // 2. Highlight potential move squares
    for (const move of playerInput.potentialMoves) {
        const { r: endR, c: endC } = move;
        ctx.fillStyle = 'rgba(79, 192, 192, 0.5)'; // Teal highlight for valid moves
        ctx.fillRect(endC * SIDE_LENGTH, endR * SIDE_LENGTH, SIDE_LENGTH, SIDE_LENGTH);
    }
}

/**
 * Main function to draw the entire game state (Board + Pieces).
 * @param {CanvasRenderingContext2D} ctx - The context to draw on.
 */
function drawGame(ctx) {
    // 1. Draw background grid
    drawBoardGrid(ctx);
    
    // 2. Draw all pieces on top of the grid
    drawPieces(ctx);

    // 3. Draw selection/move feedback
    drawSelectionVisuals(ctx);

    // 4. Draw status text
    ctx.font = "24px Arial";
    ctx.fillStyle = "rgba(0, 0, 0, 0.7)";
    ctx.textAlign = 'left';
    ctx.fillText(`Turn: ${currentTurn} | Status: ${gameStateStatus}`, 20, 30);
}

/**
 * Initializes the global game state and draws the starting board.
 */
function initializeGame() {
    const canvas = document.getElementById('chessCanvas');
    if (!canvas) {
        console.error("Canvas element with ID 'chessCanvas' not found.");
        return;
    }
    const ctx = canvas.getContext('2d');
    
    // Clear canvas completely before initialization
    ctx.clearRect(0, 0, WIDTH, HEIGHT);

    // Reset state
    boardState = initializeBoard();
    setInitialPieces(boardState);
    currentTurn = "White";
    gameStateStatus = "IN_PROGRESS";
    playerInput.selectedPiece = null;
    playerInput.potentialMoves = [];
    
    // Reset casting rights
    canCastle.White = { kingside: true, queenside: true };
    canCastle.Black = { kingside: true, queenside: true };

    // Draw the initial state
    drawGame(ctx);
    
    console.log("Game Canvas Initialized and Board Drawn.");
    
    // Set up event listeners
    canvas.addEventListener('mousedown', handleMouseDown);
    canvas.addEventListener('touchstart', handleTouchStart);
}

/** Helper to get coordinates from a known piece object placed on the board.
 * @param {Piece} piece - The piece object.
 * @returns {{r: number, c: number}} The row and column of the piece.
 */
function getCoordsFromPiece(piece) {
    for (let r = 0; r < 8; r++) {
        for (let c = 0; c < 8; c++) {
            if (boardState[r][c] === piece) {
                return { r: r, c: c };
            }
        }
    }
    return { r: -1, c: -1 }; // Should not happen if piece exists
}

/** Helper to make column indices readable (a, b, c...) */
function toReadableColumn(c) {
    let alpha = '';
    let temp;
    let i = c;
    while (i >= 0) {
        temp = i % 26;
        alpha = String.fromCharCode(97 + temp) + alpha;
        i = Math.floor(i / 26);
    }
    return alpha;
}

/** Helper to make row indices readable (1, 2, 3...) */
function toReadableRow(r) {
    // Row index r=0 (top) corresponds to Rank 8.
    // Row index r=7 (bottom) corresponds to Rank 1.
    // Rank number = 8 - r
    return 8 - r; 
}

/**
 * Traverses along a given direction vector (dr, dc) for a piece like Rook, Bishop, or Queen.
 * Updates potential moves array with all traversable squares until an obstacle or edge is hit.
 * @param {number} startR - Starting row.
 * @param {number} startC - Starting column.
 * @param {number} dr - Row increment (-1, 0, 1).
 * @param {number} dc - Column increment (-1, 0, 1).
 * @param {Array<{r: number, c: number}>} movesAccumulator - The array to push valid moves into.
 * @param {Piece} startPiece - The piece initiating the move, for checking capture rules.
 * @param {boolean} isMovePath = false - If true, it checks for blocking pieces only (e.g., for sliding pieces).
 */
function traversePath(startR, startC, dr, dc, movesAccumulator, startPiece, isMovePath = false) {
    let r = startR + dr;
    let c = startC + dc;
    
    while (r >= 0 && r < 8 && c >= 0 && c < 8) {
        const targetPiece = boardState[r][c];
        
        if (targetPiece) {
            if (targetPiece.color === startPiece.color) {
                // Blocked by a friendly piece
                break; 
            }
            // If it's an opponent piece, this is a valid move target
            if (!isMovePath) {
                movesAccumulator.push({ r: r, c: c });
            } 
            // If in move path simulation, we just note the capture and break if we can't proceed, 
            // but for sliding pieces, we keep going until the block.
            if (isMovePath) {
                movesAccumulator.push({ r: r, c: c });
            }
            
            // For sliding pieces, we MUST stop after capturing one piece if we are only validating the endpoint.
            // However, for path generation, we continue until blocked.
        } else {
            // Empty square - always valid move target
             if (!isMovePath) {
                movesAccumulator.push({ r: r, c: c });
            }
        }
        
        if (isMovePath && targetPiece && targetPiece.color !== startPiece.color) {
            // If we captured a piece, we stop the slide ONLY IF we are calculating a single move destination.
            // For generalized path generation needed here, we let it continue to check for blocks.
        }


        r += dr;
        c += dc;
    }
}


/**
 * Generates Bishop moves along two diagonals.
 * @param {Piece} piece - The piece being analyzed for moves.
 * @param {Array<{r: number, c: number}>} movesAccumulator - The array to push valid moves into.
 * @param {boolean} skipChecks - If true, this runs path traversal ignoring piece blocking for simplicity in pure path mapping.
 */
function generateBishopMoves(piece, movesAccumulator, skipChecks = false) {
    const { r: startR, c: startC } = getCoordsFromPiece(piece);

    const directions = [
        [-1, -1], [-1, 1], [1, -1], [1, 1]
    ];

    for (const [dr, dc] of directions) {
        let r = startR + dr;
        let c = startC + dc;
        while (r >= 0 && r < 8 && c >= 0 && c < 8) {
            const targetPiece = boardState[r][c];
            
            if (targetPiece) {
                if (targetPiece.color === piece.color) {
                    break; // Blocked by friendly piece
                }
                movesAccumulator.push({ r: r, c: c });
                if (!skipChecks) {
                    // If we land on an opponent piece, this is a valid capture spot, and we stop there for path calculation.
                    // For this basic generator, we assume if it's occupied, we can land there.
                    break; 
                }
            } else {
                movesAccumulator.push({ r: r, c: c });
            }
            
            r += dr;
            c += dc;
        }
    }
}

/**
 * Generates Rook moves along all orthogonal lines.
 * @param {Piece} piece - The piece being analyzed for moves.
 * @param {Array<{r: number, c: number}>} movesAccumulator - The array to push valid moves into.
 * @param {boolean} skipChecks - If true, this runs path traversal ignoring piece blocking for simplicity in pure path mapping.
 */
function generateRookMoves(piece, movesAccumulator, skipChecks = false) {
    const { r: startR, c: startC } = getCoordsFromPiece(piece);

    const directions = [
        [-1, 0], [1, 0], [0, -1], [0, 1]
    ];

    for (const [dr, dc] of directions) {
        let r = startR + dr;
        let c = startC + dc;
        while (r >= 0 && r < 8 && c >= 0 && c < 8) {
            const targetPiece = boardState[r][c];
            
            if (targetPiece) {
                if (targetPiece.color === piece.color) {
                    break; // Blocked by friendly piece
                }
                movesAccumulator.push({ r: r, c: c });
                 if (!skipChecks) {
                    // If we land on a captured piece, we stop for path calculation simplicity here.
                    break;
                }
            } else {
                movesAccumulator.push({ r: r, c: c });
            }
            
            r += dr;
            c += dc;
        }
    }
}

/**
 * Generates Queen moves by combining Rook and Bishop logic.
 * @param {Piece} piece - The piece being analyzed for moves.
 * @param {Array<{r: number, c: number}>} movesAccumulator - The array to push valid moves into.
 * @param {boolean} skipChecks - If true, this runs path traversal ignoring piece blocking for simplicity in pure path mapping.
 */
function generateQueenMoves(piece, movesAccumulator, skipChecks = false) {
    // Queen moves = Rook moves + Bishop moves
    generateRookMoves(piece, movesAccumulator, skipChecks);
    generateBishopMoves(piece, movesAccumulator, skipChecks);
}


/**
 * Generates all pseudo-legal moves for a given piece using specialized logic for N, P, R, B, Q.
 * NOTE: For this structure, we must adjust path generation functions to handle the current board state accurately within this function.
 * @param {Piece} piece - The piece being analyzed for moves.
 * @param {Array<Array<null | Piece>>} board - The current board state.
 * @param {Object} context - Dummy context object.
 * @param {boolean} isKingMove = false - If true, pass coordinate information for specific king logic (e.g., for castling check).
 * @returns {Array<{r: number, c: number}>} Array of valid target coordinates {r: row, c: column}.
 */
function generateValidMoves(piece, board, context, isKingMove = false) {
    let validMoves = [];
    const { r: startR, c: startC } = getCoordsFromPiece(piece);

    if (piece.type === 'N') {
        const knightMoves = [
            { dr: -2, dc: -1, r: startR - 2, c: startC - 1 }, 
            { dr: -2, dc: 1, r: startR - 2, c: startC + 1 },
            { dr: 2, dc: -1, r: startR + 2, c: startC - 1 }, 
            { dr: 2, dc: 1, r: startR + 2, c: startC + 1 },
            { dr: -1, dc: -2, r: startR - 1, c: startC - 2 }, 
            { dr: -1, dc: 2, r: startR - 1, c: startC + 2 },
            { dr: 1, dc: -2, r: startR + 1, c: startC - 2 }, 
            { dr: 1, dc: 2, r: startR + 1, c: startC + 2 }
        ];

        for (const move of knightMoves) {
            const r = move.r;
            const c = move.c;
            if (r >= 0 && r < 8 && c >= 0 && c < 8) {
                const targetPiece = board[r][c];
                if (!targetPiece || targetPiece.color !== piece.color) {
                    validMoves.push({ r: r, c: c });
                }
            }
        }
    } 
    else if (piece.type === 'P') {
        // Pawn movement logic
        const direction = piece.color === 'White' ? 1 : -1;
        
        // 1. Single move (forward empty)
        let oneStepR = startR + direction;
        let oneStepC = startC;
        if (oneStepR >= 0 && oneStepR < 8 && board[oneStepR][oneStepC] === null) {
            validMoves.push({ r: oneStepR, c: oneStepC });
        }

        // 2. Double move (only on starting rank, and if empty)
        if ((piece.color === 'White' && startR === 1) || (piece.color === 'Black' && startR === 6)) {
            let twoStepR = startR + 2 * direction;
            let twoStepC = startC;
            if (twoStepR >= 0 && twoStepR < 8 && board[startR + direction][startC] === null && board[twoStepR][startC] === null) {
                validMoves.push({ r: twoStepR, c: twoStepC });
            }
        }
        
        // 3. Captures (Diagonal)
        const captureOffsets = [[direction, -1], [direction, 1]];

        for (const [dr, dc] of captureOffsets) {
            let endR = startR + dr;
            let endC = startC + dc;

            if (endR >= 0 && endR < 8 && endC >= 0 && endC < 8) {
                const targetPiece = board[endR][endC];
                if (targetPiece && targetPiece.color !== piece.color) {
                    validMoves.push({ r: endR, c: endC });
                }
            }
        }
        
        // Castling check refinement (Only needed if the King moves two steps)
        if (piece.type === 'P' && Math.abs(startC - (piece.color === 'White' ? 4 : 3)) === 2) {
            // Pawns might need to handle en passant, but for this scope, we rely on the capture logic being enough.
        }
    } 
    else if (piece.type === 'R') {
        generateRookMoves(piece, validMoves, false); // Run full path check
    }
    else if (piece.type === 'B') {
        generateBishopMoves(piece, validMoves, false); // Run full path check
    }
    else if (piece.type === 'Q') {
        generateQueenMoves(piece, validMoves, false); // Run full path check
    }
    else if (piece.type === 'K') {
        // King movement (1 square in any direction)
        for (let dr = -1; dr <= 1; dr++) {
            for (let dc = -1; dc <= 1; dc++) {
                if (dr === 0 && dc === 0) continue;
                
                const r = startR + dr;
                const c = startC + dc;
                
                if (r >= 0 && r < 8 && c >= 0 && c < 8) {
                    const targetPiece = board[r][c];
                    // Prevent moving into checkmate/check here, only check if move is legal target.
                    if (!targetPiece || targetPiece.color !== piece.color) {
                         validMoves.push({ r: r, c: c });
                    }
                }
            }
        }
    }

    return validMoves;
}

/**
 * Executes move calculation for the selected piece against the current board state.
 * Adds basic castling detection capability if movement involves the King.
 * @param {Piece} piece - The piece being analyzed for moves.
 */
function calculatePotentialMoves(piece) {
    // Clear existing paths
    playerInput.potentialMoves = [];
    
    // Special Handling for King: If calculating moves, we must check if the move enables castling rights or if the King itself is involved.
    let moves = generateValidMoves(piece, boardState, {}, false);
    
    if (piece.type === 'K') {
        // If King is selected, we can refine the moves to check for castling paths specifically
        const { r: startR, c: startC } = getCoordsFromPiece(piece);
        
        // 1. Check Kingside Castling (King starts at 1, 4; Rook starts at 1, 7)
        if (piece.color === 'White' && startR === 0 && startC === 4) {
            if (canCastle.White.kingside && boardState[startR][7] === piece.type === 'R' ? createPiece('R', 'White') : null) {
                // Simulate castling move: King moves to g1 (r=0, c=6), Rook moves to f1 (r=0, c=7)
                // We add two special pseudo-moves to suggest the castling option if valid
                // Note: In a full engine, this would be handled by a special move type, but here we add coordinates.
                // Kingside Target: (0, 6)
                if (boardState[0][6] === null && boardState[0][7] === null) {
                    moves.push({ r: 0, c: 6 }); // King destination
                }
                // The actual board update needs to handle King moving AND Rook moving, which is outside simple move execution.
            }
        }
        // Repeat for Black (r=7, c=4)
    }
    
    playerInput.potentialMoves = moves;
    
    // Update state for the visualizer, even if special logic isn't fully integrated into the move list return.
}


/**
 * Helper function to execute the core mechanics of moving a piece, handling captures and en passant markers.
 * This version simulates move execution cleanly.
 * 
 * @param {Coords} startPos - Starting coordinates {r, c}.
 * @param {Coords} endPos - Ending coordinates {r, c}.
 * @param {Piece} movingPiece - The piece being moved.
 * @param {Object} stateContext - Context containing current game state data (e.g., castling rights).
 * @returns {MoveResult} Object detailing state changes.
 */
function executeMove(startPos, endPos, movingPiece, stateContext) {
    const { r: startR, c: startC } = startPos;
    const { r: endR, c: endC } = endPos;

    // Deep copy required state variables for transition simulation
    let nextBoardState = JSON.parse(JSON.stringify(boardState)); // Simple deep copy simulation (only works for primitives/simple objects, careful with class instances)
    
    // To properly simulate, we must use a true copy mechanism or pass mutable state references carefully. 
    // For this simplified context, we will operate on the passed stateCopy reference if provided, otherwise we overwrite global.
    const currentBoard = boardState; 
    
    // 1. Capture Check
    const capturedPiece = currentBoard[endR][endC];
    let captured = !!capturedPiece && capturedPiece.color !== movingPiece.color;

    // 2. Execute Board State Mutation
    
    // A. Move piece
    currentBoard[endR][endC] = movingPiece;
    // B. Clear start square
    currentBoard[startR][startC] = null;
    
    // 3. Handle Castling Logic (Specific to King movement)
    let castlingUsed = false;
    
    if (movingPiece.type === 'K') {
        const color = movingPiece.color;
        const isWhite = color === 'White';
        
        // Kingside Castling check: King moves 2 squares, and destination must be clear and safe (the path check should verify this)
        const startR_k = startR;
        const startC_k = startC;
        
        // Check if K moved two squares (assuming Kingside castling)
        if (startC_k === 4 && endC === 6 && startR_k === endR) { // Only checking candidate move to g1/g8
            // A true castling move updates BOTH K and R positions simultaneously.
            // Since the calling code only executes one move, we must assume the calling code handled the Rook move too, 
            // or we only simulate the King's move and indicate the rights change.
            
            // For simplicity in this single function wrapper, we treat this as a successful King move, 
            // and update the rights structure based on standard checks.
        }

        // Comprehensive check for King movement causing rights loss
        if (startC_k === 4 && endC !== 4 || startR_k === endR && endR !== startR) {
            // If King moved, it cannot castle again.
            if (color === 'White') {
                canCastle.White.kingside = false;
                canCastle.White.queenside = false;
            } else {
                canCastle.Black.kingside = false;
                canCastle.Black.queenside = false;
            }
        }
    }

    // 4. Handle Pawn Promotion (Simplified: Not implemented here, but this is where it goes)
    
    // 5. Update History (State logging)
    // In a real implementation, we'd record: {move: "e2-e4", result: {castling: ..., ...}, board: deepCopy}
    console.log(`Move Executed: ${movingPiece.color} ${movingPiece.type} from (${startR}, ${startC}) to (${endR}, ${endC})`);
    
    // 6. Return Move Result
    let castlingData = {};
    if (movingPiece.type === 'K') {
         if (color === 'White') {
            castlingData.kingside = canCastle.White.kingside && (startC === 4 && endC === 6);
            castlingData.queenside = canCastle.White.queenside && (startC === 4 && endC === 2);
         } else {
            castlingData.kingside = canCastle.Black.kingside && (startC === 4 && endC === 6);
            castlingData.queenside = canCastle.Black.queenside && (startC === 4 && endC === 2);
         }
    }
    
    return { 
        madeMove: true, 
        capturedPiece: captured, 
        castlingUpdate: {
            'White': { kingside: canCastle.White.kingside, queenside: canCastle.White.queenside },
            'Black': { kingside: canCastle.Black.kingside, queenside: canCastle.Black.queenside }
        },
        castlingData: castlingData
    };
}


/**
 * Handles mousedown event for mouse input.
 * @param {MouseEvent} event - The click event.
 */
function handleMouseDown(event) {
    const canvas = event.target.id === 'chessCanvas' ? event.target : document.getElementById('chessCanvas');
    if (!canvas) return;

    const rect = canvas.getBoundingClientRect();
    const clientX = event.clientX;
    const clientY = event.clientY;
    
    const x = clientX - rect.left;
    const y = clientY - rect.top;
    
    const c = Math.floor(x / SIDE_LENGTH);
    const r = Math.floor(y / SIDE_LENGTH);
    
    if (r < 0 || r >= 8 || c < 0 || c >= 8) {
        return;
    }

    const pieceAtTarget = boardState[r][c];
    const currentColor = currentTurn;

    // State 1: Attempting to select a piece
    if (!playerInput.selectedPiece) {
        if (pieceAtTarget && pieceAtTarget.color === currentColor) {
            // 1. Select the piece
            playerInput.selectedPiece = pieceAtTarget;
            
            // 2. Calculate potential moves
            calculatePotentialMoves(pieceAtTarget);
            
        } else {
            // Clear selection
            playerInput.selectedPiece = null;
            playerInput.potentialMoves = [];
        }
    } 
    // State 2: Attempting to move
    else if (playerInput.selectedPiece) {
        const targetIsMoveValid = playerInput.potentialMoves.some(move => {
            const moveR = move.r;
            const moveC = move.c;
            return moveR === r && moveC === c;
        });

        if (targetIsMoveValid) {
            // --- VALID MOVE ATTEMPT: EXECUTE MOVE ---
            
            const { r: startR, c: startC } = getCoordsFromPiece(playerInput.selectedPiece);
            
            // Execute the move and capture details
            const moveResult = executeMove(
                { r: startR, c: startC }, 
                { r: r, c: c }, 
                playerInput.selectedPiece, 
                { canCastle: canCastle }
            );

            // 3. Log and Update State
            if (moveResult.madeMove) {
                // Update global castling rights based on the move execution
                if (moveResult.castlingData) {
                    canCastle.White.kingside = moveResult.castlingData.White?.kingside || canCastle.White.kingside;
                    canCastle.White.queenside = moveResult.castlingData.White?.queenside || canCastle.White.queenside;
                    canCastle.Black.kingside = moveResult.castlingData.Black?.kingside || canCastle.Black.kingside;
                    canCastle.Black.queenside = moveResult.castlingData.Black?.queenside || canCastle.Black.queenside;
                }
                
                // 4. Reset input and switch turn
                playerInput.selectedPiece = null;
                playerInput.potentialMoves = [];
                currentTurn = currentTurn === "White" ? "Black" : "White";
                
                console.log(`TURN SWITCHED. Game Update: ${moveResult.capturedPiece ? 'Capture' : 'Move'}`);
                
                // Redraw the game board once per turn/action
                const ctx = canvas.getContext('2d');
                drawGame(ctx);
            }
            
        } else {
            // Clicked a square that is not a potential target, or clicked own piece again
            
            const targetPiece = boardState[r][c];
            const isOwnPieceClicked = targetPiece && targetPiece.color === currentColor;
            const { r: selectedR, c: selectedC } = getCoordsFromPiece(playerInput.selectedPiece);
            const isSamePieceClicked = (r === selectedR && c === selectedC);

            if (isOwnPieceClicked && !isSamePieceClicked) {
                 // New valid selection
                playerInput.selectedPiece = targetPiece;
                calculatePotentialMoves(targetPiece);
            } else {
                // Invalid click or clicked opponent's piece, clear selection
                playerInput.selectedPiece = null;
                playerInput.potentialMoves = [];
            }
            
            // Always redraw after any action that changes selection state
            const ctx = canvas.getContext('2d');
            drawGame(ctx);
        }
    } // End of if (playerInput.selectedPiece)
}

/** 
 * Handles touchstart event for mobile input.
 * @param {TouchEvent} event - The touch event.
 */
function handleTouchStart(event) {
    const canvas = event.target.id === 'chessCanvas' ? event.target : document.getElementById('chessCanvas');
    if (!canvas) return;

    event.preventDefault();
    
    const touch = event.touches[0];
    const rect = canvas.getBoundingClientRect();
    
    const clientX = touch.clientX;
    const clientY = touch.clientY;
    
    const mockEvent = {
        target: canvas,
        clientX: clientX,
        clientY: clientY,
        preventDefault: () => {}
    };

    handleMouseDown(mockEvent);
}


// Event listener to start the game loop/initialization
window.onload = initializeGame;