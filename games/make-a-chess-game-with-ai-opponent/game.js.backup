const canvas = document.getElementById("gameCanvas");
const ctx = canvas.getContext("2d");
const W = 400;
const H = 700;

const BOARD_SIZE = 8;
const TILE_SIZE = W / BOARD_SIZE;
const BOARD_HEIGHT = W; 

// Colors
const COLOR_LIGHT = "#eeeed2";
const COLOR_DARK = "#769656";
const COLOR_HIGHLIGHT = "rgba(255, 255, 0, 0.5)";
const COLOR_MOVE_TARGET = "rgba(0, 255, 0, 0.3)";
const COLOR_UI = "#222";
const COLOR_TEXT = "#fff";
const COLOR_TURN_W = "#fff";
const COLOR_TURN_B = "#aaa";

// Piece Unicode Mapping
const PIECES = {
    'r': '♜', 'n': '♞', 'b': '♝', 'q': '♛', 'k': '♚', 'p': '♟',
    'R': '♖', 'N': '♘', 'B': '♗', 'Q': '♕', 'K': '♔', 'P': '♙'
};

// Initial Board State
let board = [
    ['r', 'n', 'b', 'q', 'k', 'b', 'n', 'r'],
    ['p', 'p', 'p', 'p', 'p', 'p', 'p', 'p'],
    ['', '', '', '', '', '', '', ''],
    ['', '', '', '', '', '', '', ''],
    ['', '', '', '', '', '', '', ''],
    ['', '', '', '', '', '', '', ''],
    ['P', 'P', 'P', 'P', 'P', 'P', 'P', 'P'],
    ['R', 'N', 'B', 'Q', 'K', 'B', 'N', 'R']
];

let selectedSquare = null; // {r, c}
let turn = 'W'; // 'W' or 'B'
let statusText = "White's Turn";

const isWhite = (p) => p !== '' && p === p.toUpperCase();
const isBlack = (p) => p !== '' && p === p.toLowerCase();

function handleCanvasClick(e) {
    const rect = canvas.getBoundingClientRect();
    const x = e.clientX - rect.length; // This was a bug potential in some environments, use rect.left
    const clientX = e.clientX - rect.left;
    const clientY = e.clientY - rect.top;

    const col = Math.floor(clientX / TILE_SIZE);
    const row = Math.floor(clientY / TILE_SIZE);

    if (row >= 0 && row < BOARD_SIZE && col >= 0 && col < BOARD_SIZE) {
        if (selectedSquare) {
            const movingPiece = board[selectedSquare.r][selectedSquare.c];
            
            if (row === selectedSquare.r && col === selectedSquare.c) {
                // Deselect
                selectedSquare = null;
                statusText = turn === 'W' ? "White's Turn" : "Black's Turn";
            } else {
                // Perform Move
                // (Basic validation: don't capture your own piece)
                const targetPiece = board[row][col];
                const isTargetWhite = isWhite(targetPiece);
                const isMovingWhite = isWhite(movingPiece);

                if (targetPiece !== '' && isTargetWhite === isMovingWhite) {
                    // Illegal move: selecting opponent piece
                    selectedSquare = { r: row, c: col };
                    statusCode = "Not your piece!";
                    statusText = "Invalid Move";
                    return;
                }

                // Execute move
                board[row][col] = movingPiece;
                board[selectedSquare.r][selectedSquare.c] = '';
                
                // Switch turns and update text
                turn = (turn === 'W' ? 'B' : 'W');
                statusText = turn === 'W' ? "White's Turn" : "Black's Turn";
                selectedSquare = null;
            }
        } else {
            // Select piece
            const piece = board[row][col];
            if (piece !== '') {
                const pieceIsWhite = isWhite(piece);
                if ((turn === 'W' && pieceIsWhite) || (turn === 'B' && !pieceIsWhite)) {
                    selectedSquare = { r: row, c: col };
                    statusText = `Selected: ${PIECES[piece]}`;
                } else {
                    statusText = "Not your piece!";
                }
            }
        }
    }
}

canvas.addEventListener('mousedown', handleCanvasClick);
// Support touch for mobile
canvas.addEventListener('touchstart', (e) => {
    e.preventDefault();
    const touch = e.touches[0];
    const mouseEvent = new MouseEvent("mousedown", {
        clientX: touch.clientX,
        clientY: TLE_Y = touch.clientY, // helper
        button: 0,
    });
    // We actually need to manually map coordinates because MouseEvent doesn't support touch properly in all proxies
    // Let's use a better way:
    const rect = canvas.getBoundingClientRect();
    const fakeEvent = {
        clientX: touch.clientX,
        clientY: touch.clientY,
        target: canvas,
        clientX: touch.clientX,
        clientY: touch.clientY,
        // We'll manually trigger the logic
    };
    // Re-implementing click logic to be cleaner
}, {passive: false});

// Refactored Click Handler to handle both mouse and touch via a unified function
function processInteraction(clientX, clientY) {
    const rect = canvas.getBoundingClientRect();
    const x = clientX - rect.left;
    const y = clientY - rect.top;

    const col = Math.floor(x / TILE_SIZE);
    const row = Math.floor(y / TILE_SIZE);

    if (row >= 0 && row < BOARD_SIZE && col >= 0 && col < BOARD_SIZE) {
        if (selectedSquare) {
            const movingPiece = board[selectedSquare.r][selectedSquare.c];
            const targetPiece = board[row][col];
            const isMovingWhite = isWhite(movingPiece);
            const isTargetWhite = isWhite(targetPiece);

            if (row === selectedSquare.r && col === selectedSquare.c) {
                selectedSquare = null;
                statusText = turn === 'W' ? "White's Turn" : "Black's Turn";
            } else if (targetPiece !== '' && isTargetWhite === isMovingWhite) {
                selectedSquare = { r: row, c: col };
                statusText = "Invalid Move";
            } else {
                board[row][col] = movingPiece;
                board[selectedSquare.r][selectedSquare.c] = '';
                turn = (turn === 'W' ? 'B' : 'W');
                statusText = turn === 'W' ? "White's Turn" : "Black's Turn";
                selectedSquare = null;
            }
        } else {
            const piece = board[row][col];
            if (piece !== '') {
                if ((turn === 'W' && isWhite(piece)) || (turn === 'B' && !isWhite(piece))) {
                    selectedSquare = { r: row, c: col };
                    statusText = `Selected: ${PIECES[piece]}`;
                } else {
                    statusText = "Not your piece!";
                }
            }
        }
    }
}

canvas.addEventListener('mousedown', (e) => {
    processInteraction(e.clientX, e.clientY);
});

canvas.addEventListener('touchstart', (e) => {
    e.preventDefault();
    const rect = canvas.getBoundingClientRect();
    const touch = e.touches[0];
    processInteraction(touch.clientX, touch.clientY);
}, {passive: false});

function drawUI() {
    ctx.fillStyle = COLOR_UI;
    ctx.fillRect(0, BOARD_HEIGHT, W, H - BOARD_HEIGHT);

    ctx.fillStyle = COLOR_TEXT;
    ctx.font = "24px monospace";
    ctx.textAlign = "center";
    ctx.fillText("CHESS AI", W / 2, BOARD_HEIGHT + 50);
    
    ctx.font = "16px monospace";
    ctx.fillStyle = "#aaa";
    ctx.fillText("Strategy & Conquest", W / 2, BOARD_HEIGHT + 80);

    ctx.strokeStyle = "#444";
    ctx.lineWidth = 2;
    ctx.strokeRect(20, BOARD_HEIGHT + 120, W - 40, 150);
    
    ctx.fillStyle = turn === 'W' ? COLOR_TURN_W : COLOR_TURN_B;
    ctx.font = "bold 20px monospace";
    ctx.textAlign = "center";
    ctx.fillText(statusText, W / 2, BOARD_HEIGHT + 150);
}

function render() {
    ctx.fillStyle = "#000";
    ctx.fillRect(0, 0, W, H);

    for (let r = 0; r < BOARD_SIZE; r++) {
        for (let c = 0; c < BOARD_SIZE; c++) {
            ctx.fillStyle = (r + c) % 2 === 0 ? COLOR_LIGHT : COLOR_DARK;
            ctx.fillRect(c * TILE_SIZE, r * TILE_SIZE, TILE_SIZE, TILE_SIZE);
            
            if (selectedSquare && selectedSquare.r === r && selectedSquare.c === c) {
                ctx.fillStyle = COLOR_HIGHLIGHT;
                ctx.fillRect(c * TILE_SIZE, r * TILE_SIZE, TILE_SIZE, TILE_SIZE);
            }
        }
    }

    ctx.font = `${TILE_SIZE * 0.8}px Arial`;
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";
    for (let r = 0; r < BOARD_SIZE; r++) {
        for (let c = 0; c < BOARD_SIZE; c++) {
            const p = board[r][c];
            if (p) {
                ctx.shadowColor = "rgba(0,0,0,0.3)";
                ctx.shadowBlur = 2;
                // We don't actually need to draw black text if the unicode is colored, 
                // but for simplicity, we use the glyphs which are standard.
                // Some browsers render Unicode chess pieces in black.
                ctx.fillStyle = "#000"; 
                ctx.fillText(PIECES[p], c * TILE_SIZE + TILE_SIZE/2, r * TILE_SIZE + TILE_SIZE/2);
                ctx.shadowBlur = 0;
            }
        }
    }

    drawUI();
    requestAnimationFrame(render);
}

render();