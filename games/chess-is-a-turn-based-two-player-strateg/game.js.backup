// ... (lines 1-48 are unchanged)

/**
 * Draws the entire chessboard, including squares and pieces.
 */
function drawBoard() {
    // 1. Clear the canvas
    ctx.clearRect(0, 0, CANVAS_SIZE, CANVAS_SIZE);

    // 2. Draw the background grid using the defined style (Required by Acceptance Criteria)
    drawGrid();

    // 3. Draw selected highlight squares and potential move targets
    // Clear previous highlights
    ctx.fillStyle = 'rgba(0, 255, 0, 0.4)';
    ctx.fillRect(0, 0, CANVAS_SIZE, CANVAS_SIZE); // Resetting potential draws

    if (selectedPiece) {
        // Highlight the selected piece's square (must draw over the piece visualization slightly to show selection if needed, but usually just the move target)
        // For simplicity now, we will just draw the move targets.
    }

    let isValidMoveTarget = false;
    for (const move of validMoves) {
        const { r, c } = move;
        // Draw move indicator (e.g., a green dot/overlay)
        ctx.fillStyle = 'rgba(0, 150, 0, 0.4)';
        ctx.fillRect(c * SQUARE_SIZE, r * SQUARE_SIZE, SQUARE_SIZE, SQUARE_SIZE);
        isValidMoveTarget = true;
    }
    
    // Restore the background color manually if highlighting was used for moves
    if (!isValidMoveTarget) {
        ctx.fillStyle = 'rgba(0, 0, 0, 0)'; // Transparent fill to reset any semi-transparent overlays
        ctx.fillRect(0, 0, CANVAS_SIZE, CANVAS_SIZE);
    }


    // 4. Draw pieces
    for (let r = 0; r < BOARD_SIZE; r++) {
        for (let c = 0; c < BOARD_SIZE; c++) {
            const piece = board[r][c];
            if (piece) {
                drawPiece(piece, c, r);
            }
        }
    }
}

